# pyenv
#   For a library or app, you might want to share your .python-version if you're using pyenv
#   Otherwise, uncomment the next line
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if trust is an issue, Pipfile.lock may be excluded.
#   Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally recommended to be committed.
#   poetry.lock

# pdm
#   Similar to Pipenv and Poetry, pdm.lock is generally recommended to be committed.
#   pdm.lock

# virtualenv
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

